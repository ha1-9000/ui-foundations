<!DOCTYPE html>
{% import "macros/ui.njk" as ui %}
<html lang="en" data-brand="a" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}UI Foundations Docs</title>
    <link rel="stylesheet" href="/vendor/ui-foundations/main.css" />
    <link rel="stylesheet" href="/assets/vendor/prism/prism.css" />
    <link rel="stylesheet" href="/assets/docs.css" />
  </head>
  <body>
    <div class="docs-shell">
      <aside class="docs-sidebar">
        <a class="docs-logo" href="/">UI Foundations</a>

        <nav class="docs-nav" aria-label="Documentation navigation">
          <section class="docs-nav-section">
            <h2>Tokens</h2>
            <ul>
              {% for entry in collections.tokensDocs %}
              <li>
                <a
                  href="{{ entry.url }}"
                  {% if entry.url == page.url %}aria-current="page"{% endif %}
                >
                  {{ entry.data.navTitle or entry.data.title }}
                </a>
              </li>
              {% endfor %}
            </ul>
          </section>

          <section class="docs-nav-section">
            <h2>Components</h2>
            <ul>
              {% for entry in collections.componentsDocs %}
              <li>
                <a
                  href="{{ entry.url }}"
                  {% if entry.url == page.url %}aria-current="page"{% endif %}
                >
                  {{ entry.data.navTitle or entry.data.title }}
                </a>
              </li>
              {% endfor %}
            </ul>
          </section>

          <section class="docs-nav-section">
            <h2>EXAMPLES</h2>
            <ul>
              {% for entry in collections.examplesDocs %}
              <li>
                <a
                  href="{{ entry.url }}"
                  {% if entry.url == page.url %}aria-current="page"{% endif %}
                >
                  {{ entry.data.navTitle or entry.data.title }}
                </a>
              </li>
              {% endfor %}
            </ul>
          </section>
        </nav>
      </aside>

      <main class="docs-main">
        <header class="docs-header">
          <div class="mode-toggle" role="group" aria-label="Color mode">
            {{ ui.toggleButton("Light", "mode", "light", "outline") }}
            {{ ui.toggleButton("Dark", "mode", "dark", "outline") }}
            {{ ui.toggleButton("System", "mode", "system", "ghost") }}
          </div>

          <div class="mode-toggle" role="group" aria-label="Brand">
            {{ ui.toggleButton("Brand A", "brand", "a", "outline") }}
            {{ ui.toggleButton("Brand B", "brand", "b", "outline") }}
          </div>
        </header>

        <article class="docs-content">
          {% set compactTitleInBreadcrumb = isPlayground and breadcrumb and breadcrumb.length %}
          {% if breadcrumb and breadcrumb.length %}
          <nav class="docs-breadcrumb" aria-label="Breadcrumb">
            <ol>
              {% for item in breadcrumb %}
              <li>
                {% if item.url %}
                <a href="{{ item.url }}">{{ item.label }}</a>
                {% else %}
                <span aria-current="page">{{ item.label }}</span>
                {% endif %}
              </li>
              {% endfor %}
            </ol>
          </nav>
          {% endif %}
          {% if title and not compactTitleInBreadcrumb %}<h1>{{ title }}</h1>{% endif %}
          {% if description and not isPlayground %}<p class="page-intro">{{ description }}</p>{% endif %}
          {% if playgroundUrl %}
          <p class="docs-page-actions">
            <a class="docs-page-link" href="{{ playgroundUrl }}">
              {{ playgroundLabel or "Open Playground" }}
            </a>
          </p>
          {% endif %}
          {{ content | safe }}
        </article>
      </main>
    </div>

    <script>
      const root = document.documentElement;
      const modeButtons = document.querySelectorAll("[data-mode]");
      const brandButtons = document.querySelectorAll("[data-brand]");
      const systemDarkMedia = window.matchMedia("(prefers-color-scheme: dark)");
      const storedMode = localStorage.getItem("ui-foundations-mode");
      const storedBrand = localStorage.getItem("ui-foundations-brand");
      let selectedMode = "light";

      const updateModePressedState = (mode) => {
        modeButtons.forEach((button) => {
          const active =
            mode === "system"
              ? button.dataset.mode === "system"
              : button.dataset.mode === mode;
          button.setAttribute("aria-pressed", active ? "true" : "false");
        });
      };

      const updateBrandPressedState = (brand) => {
        brandButtons.forEach((button) => {
          const active = button.dataset.brand === brand;
          button.setAttribute("aria-pressed", active ? "true" : "false");
        });
      };

      const applyMode = (mode) => {
        selectedMode = mode;
        if (mode === "system") {
          root.dataset.mode = systemDarkMedia.matches ? "dark" : "light";
          updateModePressedState("system");
          return;
        }

        root.dataset.mode = mode;
        updateModePressedState(mode);
      };

      const applyBrand = (brand) => {
        root.dataset.brand = brand;
        updateBrandPressedState(brand);
      };

      applyMode(storedMode || "light");
      applyBrand(storedBrand || "a");

      if (typeof systemDarkMedia.addEventListener === "function") {
        systemDarkMedia.addEventListener("change", () => {
          if (selectedMode === "system") {
            root.dataset.mode = systemDarkMedia.matches ? "dark" : "light";
          }
        });
      } else if (typeof systemDarkMedia.addListener === "function") {
        systemDarkMedia.addListener(() => {
          if (selectedMode === "system") {
            root.dataset.mode = systemDarkMedia.matches ? "dark" : "light";
          }
        });
      }

      modeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const mode = button.dataset.mode;
          applyMode(mode);
          localStorage.setItem("ui-foundations-mode", mode);
        });
      });

      brandButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const brand = button.dataset.brand;
          applyBrand(brand);
          localStorage.setItem("ui-foundations-brand", brand);
        });
      });
    </script>
    <script src="/assets/vendor/prism/prism.js"></script>
    <script src="/assets/vendor/prism/prism-markup.min.js"></script>
    <script src="/assets/vendor/prism/prism-jsx.min.js"></script>
    <script src="/assets/playground/shared.js"></script>
    <script src="/assets/playground/state.js"></script>
    <script src="/assets/playground/code.js"></script>
    <script src="/assets/playground/renderers.js"></script>
    <script src="/assets/playground.js"></script>
  </body>
</html>
