{% macro playground(config) -%}
{%- set playgroundId = config.id or "ui-playground" -%}
{%- set runtime = config.runtime or "vanilla" -%}
{%- set renderer = config.renderer or "" -%}
{%- set componentExport = config.componentExport or config.componentName or "" -%}
{%- set queryPrefix = config.queryPrefix or playgroundId -%}
<div
  class="playground-grid"
  data-playground
  data-runtime="{{ runtime }}"
  data-renderer="{{ renderer }}"
  data-query-prefix="{{ queryPrefix }}"
  {% if config.componentName %}data-component-name="{{ config.componentName }}"{% endif %}
  {% if config.componentModule %}data-component-module="{{ config.componentModule }}"{% endif %}
  {% if componentExport %}data-component-export="{{ componentExport }}"{% endif %}
  data-playground-id="{{ playgroundId }}"
>
  <div class="playground-preview playground-panel">
    <div id="{{ playgroundId }}-root" class="playground-stage"></div>
  </div>

  <aside class="playground-controls-panel playground-panel">
    <form class="playground-controls" id="{{ playgroundId }}-controls">
      {% for control in config.controls %}
      {% set controlId = playgroundId + "-" + control.name %}
      {% set source = control.source or "prop" %}
      {% set valueType = control.valueType or ("boolean" if control.kind == "boolean" else "string") %}
      {% set queryParam = control.query or false %}
      {% if control.kind == "boolean" %}
      <label
        class="playground-field playground-check"
        for="{{ controlId }}"
        data-playground-field
        data-control-name="{{ control.name }}"
        data-visible-when="{% if control.visibleWhen %}{% for conditionName, conditionValue in control.visibleWhen %}{% if not loop.first %};{% endif %}{{ conditionName }}={{ conditionValue }}{% endfor %}{% endif %}"
      >
        <input
          id="{{ controlId }}"
          type="checkbox"
          name="{{ control.name }}"
          data-playground-control
          data-prop="{{ control.prop or control.name }}"
          data-source="{{ source }}"
          data-value-type="{{ valueType }}"
          data-query-param="{{ "1" if queryParam else "0" }}"
          {% if control.default %}checked{% endif %}
        />
        <span>{{ control.label or control.name }}</span>
      </label>
      {% elif control.kind == "color" %}
      <label
        class="playground-field"
        for="{{ controlId }}"
        data-playground-field
        data-control-name="{{ control.name }}"
        data-visible-when="{% if control.visibleWhen %}{% for conditionName, conditionValue in control.visibleWhen %}{% if not loop.first %};{% endif %}{{ conditionName }}={{ conditionValue }}{% endfor %}{% endif %}"
      >
        <span>{{ control.label or control.name }}</span>
        <div class="playground-color-inline">
          <input
            id="{{ controlId }}"
            type="text"
            name="{{ control.name }}"
            value="{{ control.default or "currentColor" }}"
            data-playground-control
            data-prop="{{ control.prop or control.name }}"
            data-source="{{ source }}"
            data-value-type="{{ valueType }}"
            data-query-param="{{ "1" if queryParam else "0" }}"
          />
          <button
            type="button"
            class="button ghost playground-color-pick"
            data-playground-color-button
            data-target-control="{{ controlId }}"
          >
            Pick
          </button>
          <input
            id="{{ controlId }}-picker"
            type="color"
            value="#000000"
            data-playground-color-picker
            data-target-control="{{ controlId }}"
            aria-label="Pick color for {{ control.label or control.name }}"
          />
        </div>
      </label>
      {% elif control.kind == "select" %}
      <label
        class="playground-field"
        for="{{ controlId }}"
        data-playground-field
        data-control-name="{{ control.name }}"
        data-visible-when="{% if control.visibleWhen %}{% for conditionName, conditionValue in control.visibleWhen %}{% if not loop.first %};{% endif %}{{ conditionName }}={{ conditionValue }}{% endfor %}{% endif %}"
      >
        <span>{{ control.label or control.name }}</span>
        <select
          id="{{ controlId }}"
          name="{{ control.name }}"
          data-playground-control
          data-prop="{{ control.prop or control.name }}"
          data-source="{{ source }}"
          data-value-type="{{ valueType }}"
          data-query-param="{{ "1" if queryParam else "0" }}"
        >
          {% if control.optionsData == "icons" %}
          {% for option in iconNames.names %}
          <option value="{{ option }}"{% if option == (control.default or "") %} selected{% endif %}>{{ option }}</option>
          {% endfor %}
          {% elif control.optionsData == "iconsWithNone" %}
          {% for option in iconNames.withNone %}
          {% set optionValue = option %}
          {% set optionLabel = option %}
          {% if option and option.value is defined %}
          {% set optionValue = option.value %}
          {% set optionLabel = option.label if option.label is defined else option.value %}
          {% endif %}
          <option value="{{ optionValue }}"{% if optionValue == (control.default or "") %} selected{% endif %}>{{ optionLabel }}</option>
          {% endfor %}
          {% else %}
          {% for option in control.options or [] %}
          {% set optionValue = option %}
          {% set optionLabel = option %}
          {% if option and option.value is defined %}
          {% set optionValue = option.value %}
          {% set optionLabel = option.label if option.label is defined else option.value %}
          {% endif %}
          <option value="{{ optionValue }}"{% if optionValue == (control.default or "") %} selected{% endif %}>{{ optionLabel }}</option>
          {% endfor %}
          {% endif %}
        </select>
      </label>
      {% else %}
      <label
        class="playground-field"
        for="{{ controlId }}"
        data-playground-field
        data-control-name="{{ control.name }}"
        data-visible-when="{% if control.visibleWhen %}{% for conditionName, conditionValue in control.visibleWhen %}{% if not loop.first %};{% endif %}{{ conditionName }}={{ conditionValue }}{% endfor %}{% endif %}"
      >
        <span>{{ control.label or control.name }}</span>
        <input
          id="{{ controlId }}"
          type="{{ control.kind or "text" }}"
          name="{{ control.name }}"
          value="{{ control.default or "" }}"
          data-playground-control
          data-prop="{{ control.prop or control.name }}"
          data-source="{{ source }}"
          data-value-type="{{ valueType }}"
          data-query-param="{{ "1" if queryParam else "0" }}"
        />
      </label>
      {% endif %}
      {% endfor %}
      <div class="playground-actions">
        <button type="button" class="button ghost" data-playground-reset>
          Reset
        </button>
      </div>
    </form>
  </aside>

  <section class="playground-code-panel">
    <pre class="playground-code"><code id="{{ playgroundId }}-code"></code></pre>
  </section>
</div>
{%- endmacro %}
