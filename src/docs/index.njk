      </section>
    </main>
    <script>
      const root = document.documentElement;
      const buttons = document.querySelectorAll("[data-mode]");
      const stored = localStorage.getItem("ui-foundations-mode");

      const updatePressedState = (mode) => {
        buttons.forEach((button) => {
          const active =
            mode === "system"
              ? button.dataset.mode === "system"
              : button.dataset.mode === mode;
          button.setAttribute("aria-pressed", active ? "true" : "false");
        });
      };

      if (stored) {
        root.dataset.mode = stored;
        updatePressedState(stored);
      } else {
        root.dataset.mode = "light";
        updatePressedState("light");
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const mode = button.dataset.mode;
          if (mode === "system") {
            root.dataset.mode = "light";
            localStorage.setItem("ui-foundations-mode", "light");
            updatePressedState("light");
            return;
          }
          root.dataset.mode = mode;
          localStorage.setItem("ui-foundations-mode", mode);
          updatePressedState(mode);
        });
      });
    </script>
  </body>
</html>
