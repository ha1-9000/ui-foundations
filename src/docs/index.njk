<!DOCTYPE html>
<html lang="en" data-brand="a" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UI Foundations Examples</title>
    <link rel="stylesheet" href="/main.css" />
  </head>
  <body>
    <main class="page">
      <h1>UI Foundations Examples</h1>
      <div class="mode-toggle" role="group" aria-label="Color mode">
        <button
          class="button outline"
          type="button"
          data-mode="light"
          aria-pressed="false"
        >
          Light
        </button>
        <button
          class="button outline"
          type="button"
          data-mode="dark"
          aria-pressed="false"
        >
          Dark
        </button>
        <button
          class="button ghost"
          type="button"
          data-mode="system"
          aria-pressed="false"
        >
          System
        </button>
      </div>
      <div class="mode-toggle" role="group" aria-label="Brand">
        <button
          class="button outline"
          type="button"
          data-brand="a"
          aria-pressed="false"
        >
          Brand A
        </button>
        <button
          class="button outline"
          type="button"
          data-brand="b"
          aria-pressed="false"
        >
          Brand B
        </button>
      </div>
      <section>
        <p>Token + pattern preview.</p>
        <div class="button-group">
          <button type="button" class="button">Solid</button>
          <button type="button" class="button outline">Outline</button>
          <button type="button" class="button ghost">Ghost</button>
          <button type="button" class="button" disabled>Disabled</button>
        </div>
      </section>
      <section class="typography">
        <h2 class="heading-xxl">Typography</h2>
        <div class="type-grid">
          <div class="type-card">
            <p class="type-meta">h1 (default)</p>
            <h1>Journeys are measured in stories.</h1>
          </div>
          <div class="type-card">
            <p class="type-meta">Heading class (xl)</p>
            <p class="heading-xl">Journeys are measured in stories.</p>
          </div>
          <div class="type-card">
            <p class="type-meta">Body (md)</p>
            <p class="body text--md">
              Clear schedules, gentle spacing, and readable copy for every
              screen.
            </p>
          </div>
          <div class="type-card">
            <p class="type-meta">Code</p>
            <p class="type-sample"><code>const ticketId = "ZX-418";</code></p>
          </div>
        </div>
        <div class="type-scale">
          <div class="type-scale-row">
            <span class="type-scale-label">heading-xxxl</span>
            <span class="type-scale-sample heading-xxxl">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">heading-xxl</span>
            <span class="type-scale-sample heading-xxl">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">heading-xl</span>
            <span class="type-scale-sample heading-xl">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">heading-lg</span>
            <span class="type-scale-sample heading-lg">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">heading-md</span>
            <span class="type-scale-sample heading-md">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">heading-sm</span>
            <span class="type-scale-sample heading-sm">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--xs</span>
            <span class="type-scale-sample text--xs">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--sm</span>
            <span class="type-scale-sample text--sm">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--md</span>
            <span class="type-scale-sample text--md">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--lg</span>
            <span class="type-scale-sample text--lg">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--xl</span>
            <span class="type-scale-sample text--xl">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--2xl</span>
            <span class="type-scale-sample text--2xl">Sample</span>
          </div>
          <div class="type-scale-row">
            <span class="type-scale-label">text--3xl</span>
            <span class="type-scale-sample text--3xl">Sample</span>
          </div>
        </div>
      </section>
      <section class="palette">
        <h2>Color palette</h2>
        <div class="palette-group">
          <h3>Brand</h3>
          <div class="swatch-grid">
            <div class="swatch" style="--swatch-color: var(--brand-color-primary)">
              <span>brand-color-primary</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-primary-dark)"
            >
              <span>brand-color-primary-dark</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-accent)"
            >
              <span>brand-color-accent</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-accent-dark)"
            >
              <span>brand-color-accent-dark</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-functional-base)"
            >
              <span>brand-color-functional-base</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-functional-base-dark)"
            >
              <span>brand-color-functional-base-dark</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-functional-success)"
            >
              <span>brand-color-functional-success</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--brand-color-functional-danger)"
            >
              <span>brand-color-functional-danger</span>
            </div>
          </div>
        </div>
        <div class="palette-group">
          <h3>Neutral</h3>
          <div class="swatch-grid">
            <div
              class="swatch"
              style="--swatch-color: var(--color-transparent)"
            >
              <span>transparent</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-1000)"
            >
              <span>neutral-1000</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-800)"
            >
              <span>neutral-800</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-500)"
            >
              <span>neutral-500</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-200)"
            >
              <span>neutral-200</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-000)"
            >
              <span>neutral-000</span>
            </div>
          </div>
        </div>
        <div class="palette-group">
          <h3>Overlay</h3>
          <div class="swatch-grid">
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-900)"
            >
              <span>neutral-alpha-900</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-800)"
            >
              <span>neutral-alpha-800</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-700)"
            >
              <span>neutral-alpha-700</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-600)"
            >
              <span>neutral-alpha-600</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-500)"
            >
              <span>neutral-alpha-500</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-400)"
            >
              <span>neutral-alpha-400</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-300)"
            >
              <span>neutral-alpha-300</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-200)"
            >
              <span>neutral-alpha-200</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-100)"
            >
              <span>neutral-alpha-100</span>
            </div>
            <div
              class="swatch"
              style="--swatch-color: var(--color-neutral-alpha-000)"
            >
              <span>neutral-alpha-000</span>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script>
      const root = document.documentElement;
      const modeButtons = document.querySelectorAll("[data-mode]");
      const brandButtons = document.querySelectorAll("[data-brand]");
      const stored = localStorage.getItem("ui-foundations-mode");
      const storedBrand = localStorage.getItem("ui-foundations-brand");

      const updateModePressedState = (mode) => {
        modeButtons.forEach((button) => {
          const active =
            mode === "system"
              ? button.dataset.mode === "system"
              : button.dataset.mode === mode;
          button.setAttribute("aria-pressed", active ? "true" : "false");
        });
      };

      const updateBrandPressedState = (brand) => {
        brandButtons.forEach((button) => {
          const active = button.dataset.brand === brand;
          button.setAttribute("aria-pressed", active ? "true" : "false");
        });
      };

      const applyMode = (mode) => {
        if (mode === "system") {
          root.removeAttribute("data-mode");
          updateModePressedState("system");
          return;
        }
        root.dataset.mode = mode;
        updateModePressedState(mode);
      };

      const applyBrand = (brand) => {
        root.dataset.brand = brand;
        updateBrandPressedState(brand);
      };

      if (stored) {
        applyMode(stored);
      } else {
        applyMode("light");
      }

      if (storedBrand) {
        applyBrand(storedBrand);
      } else {
        applyBrand("a");
      }

      modeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const mode = button.dataset.mode;
          applyMode(mode);
          localStorage.setItem("ui-foundations-mode", mode);
        });
      });

      brandButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const brand = button.dataset.brand;
          applyBrand(brand);
          localStorage.setItem("ui-foundations-brand", brand);
        });
      });
    </script>
  </body>
</html>
